generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Customer {
  id          String   @id
  name        String
  email       String   @unique
  password    String
  address     String
  district    String
  type        String
  residents   Int
  heatingType String
  hasSolar    Boolean
  hasEvCharger Boolean
  joinedDate  DateTime
  avatar      String
  invoices    Invoice[]
  rewards     Reward[]
}

model Invoice {
  id         String   @id
  customerId String
  month      String
  amount     Float
  paid       Boolean
  dueDate    String
  type       String
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Reward {
  id          String   @id
  customerId  String
  title       String
  description String
  points      Int
  category    String
  claimed     Boolean
  expiresAt   String
  customer    Customer @relation(fields: [customerId], references: [id])
}

model UsageRecord {
  id          String @id
  customerId  String
  month       String
  heating     Float
  electricity Float
  temperature Float
}

model CommunityEvent {
  id           String @id
  title        String
  date         String
  location     String
  type         String
  participants Int
  image        String
}

model Neighbourhood {
  id                String  @id
  name              String
  districtHeating   Boolean
  expansionPlanned  Boolean
  expansionYear     String
  carbonSaved       Int
  homesConnected    Int
  renewablePercentage Int
  communityProjects Int
}

model Sustainability {
  id                      String @id
  co2Saved                Int
  renewableGeneration     Float
  districtHeatingAdoption Int
  homesConnected          Int
  futureTarget            Int
  treesEquivalent         Int
}

model WeatherRecord {
  id          String  @id
  temperature Float
  condition   String
  humidity    Int
  windSpeed   Float
}
